# ==============================================================================
# LMS AI Chatbot Project .gitignore
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Environment Variables & Secrets (가장 중요 - API 키 유출 방지)
# ------------------------------------------------------------------------------
.env
.env.*
!.env.example

# ------------------------------------------------------------------------------
# 2. Database & RAG Data (용량 및 보안 문제 방지)
# ------------------------------------------------------------------------------
# ChromaDB 로컬 벡터 저장소
chroma_db/
backend/chroma_db/

# RAG 학습용 원본 사내 문서 (PDF, TXT 등 기밀 자료)
data/
backend/data/
backend/uploads/

# MariaDB 로컬 볼륨 마운트 (만약 로컬 폴더로 마운트했을 경우를 대비)
mysql_data/
mariadb_data/

# ------------------------------------------------------------------------------
# 3. Python / Backend (FastAPI, LangGraph)
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.coverage
htmlcov/
backend/gcp-key.json

# 가상환경
venv/
.venv/
env/
.env_python/

# ------------------------------------------------------------------------------
# 4. Node / Frontend (React + Vite)
# ------------------------------------------------------------------------------
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/dist-ssr/
frontend/*.local

# npm / yarn / pnpm 로그
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ------------------------------------------------------------------------------
# 5. OS & IDE / Editor
# ------------------------------------------------------------------------------
# Mac / Windows 시스템 파일
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# VSCode, IntelliJ 등 에디터 설정
.vscode/
.idea/
*.swp
*.swo

# 참고: .cursorrules 파일은 AI 에디터의 공통 규칙이므로 팀원과 공유하기 위해 Git에 포함시킵니다. (무시하지 않음)
backend_logs.txt
